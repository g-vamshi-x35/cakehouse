# Resend (https://resend.com) — powers the contact form and order/payment emails.
# 1. Create a Resend account and API key.
# 2. Verify a sending domain (or use the onboarding@resend.dev test sender for now).
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL="Cake House Website <onboarding@resend.dev>"

# Supabase (https://supabase.com) — Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used for admin actions (webhooks, cron, seeding).
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (https://dashboard.razorpay.com) — Settings -> API Keys. Test keys are fine to start.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Minimum advance payment required at checkout (in INR).
NEXT_PUBLIC_MIN_ADVANCE_AMOUNT=200

# Secret used to authorize the daily birthday-reminder cron endpoint.
CRON_SECRET=
